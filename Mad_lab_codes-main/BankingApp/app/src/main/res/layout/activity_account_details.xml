<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_grey"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCOUNT DETAILS"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/blue_header"
            android:layout_marginBottom="25dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Bank Branch:"
            android:textColor="@color/label_color"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"/>
        <Spinner
            android:id="@+id/spinnerBranch"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@color/edit_text_bg"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Services Needed:"
            android:textColor="@color/label_color"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"/>
        <ListView
            android:id="@+id/lvServices"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:choiceMode="multipleChoice"
            android:background="@color/edit_text_bg"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnPickDate"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="SELECT OPENING DATE"
            android:layout_marginBottom="10dp"
            android:backgroundTint="@color/white"
            android:textColor="@color/black"/>

        <Button
            android:id="@+id/btnPickTime"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="SELECT OPENING TIME"
            android:layout_marginBottom="10dp"
            android:backgroundTint="@color/white"
            android:textColor="@color/black"/>

        <Button
            android:id="@+id/btnAccountMode"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="CHOOSE MODE: ONLINE/OFFLINE"
            android:layout_marginBottom="30dp"
            android:backgroundTint="@color/white"
            android:textColor="@color/black"/>

        <Button
            android:id="@+id/btnNextAccount"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CONFIRM AND NEXT"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/blue_header"
            android:textColor="@color/white"/>
    </LinearLayout>
</ScrollView>
