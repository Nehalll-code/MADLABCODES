<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/serviceDetailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Booking Details"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Center"
            android:textSize="16sp"
            android:layout_marginBottom="5dp" />

        <Spinner
            android:id="@+id/spinnerCenter"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@android:color/white"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Issues"
            android:textSize="16sp"
            android:layout_marginBottom="5dp" />

        <ListView
            android:id="@+id/listViewIssues"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@android:color/white"
            android:choiceMode="multipleChoice"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnDate"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Select Date"
                android:layout_marginRight="5dp" />

            <Button
                android:id="@+id/btnTime"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Select Time"
                android:layout_marginLeft="5dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date: Not Set | Time: Not Set"
            android:textAlignment="center"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnSlot"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Select Slot (PopupMenu)"
            android:backgroundTint="@color/darker_gray"
            android:layout_marginBottom="30dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSummary"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="VIEW SUMMARY"
            android:textColor="@color/white"
            android:background="@android:color/black" />

    </LinearLayout>
</ScrollView>
